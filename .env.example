# AutoPilot Environment Variables
# Please copy this file to .env and fill in the values

# Neon PostgreSQL Database Connection String
# 1. Go to https://neon.tech/ and sign up for a free account (no credit card needed)
# 2. Create a new project.
# 3. From the Dashboard, find the "Connection Details" widget.
# 4. Copy the "Postgres" connection string.
# 5. Paste it below:
DATABASE_URL="postgresql://user:password@ep-cool-snowflake-123456.us-east-2.aws.neon.tech/neondb?sslmode=require"

# JWT Secret for Edge signing (Next.js API route)
# You can generate a secure random string and paste it here, for example:
# Generate one using `openssl rand -base64 32` or similar.
JWT_SECRET="your-super-secret-jwt-key-replace-me-in-production"
