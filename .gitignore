# ─────────────────────────────────────────────────────────────
# Root .gitignore — AutoPilot Monorepo
# Applies to both /frontend and /backend unless overridden
# ─────────────────────────────────────────────────────────────

# ── OS & Editor ──────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
Thumbs.db
ehthumbs.db
Desktop.ini
*.pem

# Editor config / IDE
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ── Logs ─────────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ── Dependencies ─────────────────────────────────────────────
node_modules/
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# ── Environment Variables ────────────────────────────────────
# NEVER commit secrets or API keys
*.env
*.env.*
*!.env.example

# ── Build Outputs ────────────────────────────────────────────
dist/
out/
build/

# ── TypeScript ───────────────────────────────────────────────
*.tsbuildinfo

# ── Testing / Coverage ───────────────────────────────────────
coverage/
.nyc_output/

# ── Misc ─────────────────────────────────────────────────────
*.pem
.vercel
.netlify
