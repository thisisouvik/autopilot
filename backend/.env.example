# ─────────────────────────────────────────────────────────────
# backend/.env.example
# Copy this file to .env and fill in all values before running
# ─────────────────────────────────────────────────────────────

# ── Database ─────────────────────────────────────────────────
# Neon PostgreSQL connection string
# 1. Go to https://neon.tech/ and sign up for free (no credit card)
# 2. Create a new project
# 3. From Dashboard → Connection Details → copy "Postgres" URL
DATABASE_URL="postgresql://user:password@ep-cool-snowflake-123456.us-east-2.aws.neon.tech/neondb?sslmode=require"

# ── Auth ─────────────────────────────────────────────────────
# Secret key used to sign and verify JWTs (HttpOnly cookies)
# Generate a strong random key: openssl rand -base64 32
JWT_SECRET="your-super-secret-jwt-key-replace-me-in-production"

# ── AI (Groq) ─────────────────────────────────────────────────
# Used by the AI chat route to call Qwen3 via Groq
# 1. Go to https://console.groq.com/keys
# 2. Sign in for free, click "Create API Key"
# 3. Paste the key below
GROQ_API_KEY="gsk_your_groq_api_key_here"

# ── Redis (Upstash) ───────────────────────────────────────────
# Used for: rate limiting, Horizon cursor tracking, caching
# FREE tier — no credit card needed (10,000 commands/day)
# 1. Go to https://console.upstash.com and sign up for free
# 2. Click "Create Database" → choose "Redis" → pick any region
# 3. After creation, go to the database page
# 4. Scroll down to "REST API" section
# 5. Copy "UPSTASH_REDIS_REST_URL" and "UPSTASH_REDIS_REST_TOKEN" below
UPSTASH_REDIS_REST_URL="https://your-redis-name.upstash.io"
UPSTASH_REDIS_REST_TOKEN="your_upstash_rest_token_here"
# NOTE: If left empty, the app still works — Redis features degrade gracefully

# Redis TCP URL — needed by BullMQ job queue (ioredis connection)
# From the SAME Upstash database — go to: Dashboard → your DB → Details tab
# Copy the field labelled "Redis URL" or "Endpoint" and format as:
# rediss://:YOUR_TOKEN@YOUR_ENDPOINT:6379
REDIS_URL="rediss://:your_upstash_token@your-redis.upstash.io:6379"

# ── Stellar Automation Engine ─────────────────────────────────
# The server-side Stellar keypair used to execute transactions on-chain
# Generate BOTH the keypair AND encryption key in one step:
#   npm run gen-keypair
# Then fund the account on testnet:
#   npm run friendbot
AUTOPILOT_SECRET_KEY="S...your_stellar_secret_key..."
AUTOPILOT_PUBLIC_KEY="G...your_stellar_public_key..."

# ── Vault Encryption ──────────────────────────────────────────
# AES-256-GCM key used to encrypt vault secret keys in the database
# Generated automatically by: npm run gen-keypair
# Must be a 64-character hex string (32 bytes)
# NEVER change this after vaults are created — you'll lose access to them
VAULT_ENCRYPTION_KEY="your_64_char_hex_key_here"

# Stellar network ("testnet" or "mainnet")
STELLAR_NETWORK="testnet"

# Horizon API endpoint (leave as default for testnet)
HORIZON_URL="https://horizon-testnet.stellar.org"

# ── Engine Security ───────────────────────────────────────────
# Secret header used to authenticate worker → backend calls
# Can be the same as JWT_SECRET or a separate value
ENGINE_SECRET="your-engine-secret-matches-jwt-secret"

# ── Server ───────────────────────────────────────────────────
# Port the Fastify server listens on (default: 3001)
PORT=3001

# Frontend URL for CORS (set to your Vercel URL in production)
FRONTEND_URL="http://localhost:3000"

# Runtime environment
NODE_ENV="development"
