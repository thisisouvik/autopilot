# ─────────────────────────────────────────────────────────────
# backend/.gitignore — Fastify / Node.js
# ─────────────────────────────────────────────────────────────

# ── Build output (TypeScript compiled JS) ────────────────────
dist/

# ── Dependencies ─────────────────────────────────────────────
*node_modules/

# ── Environment Variables — NEVER commit secrets ──────────────
.env
.env.*
!.env.example

# ── Logs ─────────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*

# ── TypeScript build cache ────────────────────────────────────
*.tsbuildinfo

# ── OS files ─────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── Deployment platform folders ──────────────────────────────
.render/
.railway/

# ── Temp / scratch ───────────────────────────────────────────
tmp/
temp/
