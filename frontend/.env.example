# ─────────────────────────────────────────────────────────────
# frontend/.env.example
# Copy this file to .env and fill in only the values needed
# for the Next.js frontend. Most secrets live in backend/.env
# ─────────────────────────────────────────────────────────────

# URL of the deployed Fastify backend (used by Next.js rewrites in production)
# In development this defaults to http://localhost:3001 automatically
# On Vercel, set this to your backend's deployed URL (e.g. on Render)
NEXT_PUBLIC_API_URL="http://localhost:3001"
